# Git LFS rules — track all video files via Git LFS
videos/**/*.mp4 filter=lfs diff=lfs merge=lfs -text
videos/**/*.webm filter=lfs diff=lfs merge=lfs -text
videos/**/*.mov filter=lfs diff=lfs merge=lfs -text

# Also track the UVD example video and any other large assets
methods/**/*.mp4 filter=lfs diff=lfs merge=lfs -text
methods/**/*.pth filter=lfs diff=lfs merge=lfs -text
methods/**/*.pt filter=lfs diff=lfs merge=lfs -text
benchmarks/**/*.mp4 filter=lfs diff=lfs merge=lfs -text
